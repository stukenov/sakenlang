{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "sakenlang",
  "scopeName": "source.sakenlang",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#constants" },
    { "include": "#keywords" },
    { "include": "#declarations" },
    { "include": "#builtins" },
    { "include": "#functions" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [{
        "name": "comment.line.double-slash.sakenlang",
        "match": "//.*$"
      }]
    },
    "strings": {
      "patterns": [{
        "name": "string.quoted.double.sakenlang",
        "begin": "\"",
        "end": "\"",
        "patterns": [{
          "name": "constant.character.escape.sakenlang",
          "match": "\\\\."
        }]
      }]
    },
    "numbers": {
      "patterns": [{
        "name": "constant.numeric.sakenlang",
        "match": "\\b[0-9]+\\b"
      }]
    },
    "constants": {
      "patterns": [{
        "name": "constant.language.sakenlang",
        "match": "\\b(true|false)\\b"
      }]
    },
    "keywords": {
      "patterns": [{
        "name": "keyword.control.sakenlang",
        "match": "\\b(if|else|while|return)\\b"
      }]
    },
    "declarations": {
      "patterns": [
        {
          "name": "keyword.declaration.sakenlang",
          "match": "\\b(let|var|func)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [{
        "name": "support.function.sakenlang",
        "match": "\\b(print|len|route|serve|param|header|status)\\b"
      }]
    },
    "functions": {
      "patterns": [{
        "match": "\\b(func)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
        "captures": {
          "1": { "name": "keyword.declaration.sakenlang" },
          "2": { "name": "entity.name.function.sakenlang" }
        }
      }]
    },
    "operators": {
      "patterns": [{
        "name": "keyword.operator.sakenlang",
        "match": "(==|!=|&&|\\|\\||[+\\-*/=<>!])"
      }]
    }
  }
}
